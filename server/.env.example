# ── LLM 配置 ─────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
CHAT_MODEL=gpt-3.5-turbo
EMBEDDING_MODEL=text-embedding-ada-002

# ── 数据库 ───────────────────────────────────────────
# 默认使用本地 SQLite 数据库。
DATABASE_URL=sqlite:///./data/nexchat.db

# ── 向量数据库 (ChromaDB) ────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma

# ── 文件上传 ─────────────────────────────────────────
UPLOAD_DIR=./data/uploads
# 单文件最大字节数（默认 10MB）
MAX_UPLOAD_SIZE=10485760

# ── RAG 配置 ─────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=5

# ── 服务监听 ─────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── 安全鉴权 ─────────────────────────────────────────
# Optional. Leave empty for local/simple demo.
# Set this only if you want to protect a public backend.
DEMO_TOKEN=

# ── CORS 允许来源（JSON 数组，须用双引号） ────────────
# 多个来源用逗号分隔，例如：["http://localhost:5173","https://example.com"]
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
